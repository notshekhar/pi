{
  "name": "pi-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm -w @notshekhar/pi-core run build --silent && tsx packages/cli/src/cli.ts",
    "dev:fast": "tsx packages/cli/src/cli.ts",
    "build": "npm run gen:catalog && npm -w @notshekhar/pi-core run build && npm -w @notshekhar/pi run build",
    "gen:catalog": "tsx packages/core/src/catalog/scripts/generate.ts",
    "link": "npm -w @notshekhar/pi run build && npm -w @notshekhar/pi link",
    "typecheck": "npm -w @notshekhar/pi-core run typecheck && npm -w @notshekhar/pi run typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
