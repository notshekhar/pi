{
  "name": "@notshekhar/pi-tui",
  "version": "0.0.2",
  "description": "TUI renderer for pi — differential rendering, editor, markdown, select lists. Port of @earendil-works/pi-tui (MIT, Mario Zechner / earendil-works).",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/notshekhar/pi#readme",
  "bugs": {
    "url": "https://github.com/notshekhar/pi/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/notshekhar/pi.git",
    "directory": "packages/tui"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build.ts && tsc -p tsconfig.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "get-east-asian-width": "^1.6.0",
    "marked": "^15.0.12"
  }
