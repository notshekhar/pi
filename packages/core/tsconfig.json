{
    // Typecheck-only project. core is bundled via build.ts (esbuild/bun) and
    // ships no .d.ts (package.json has no "types"), so it doesn't emit
    // declarations. Keeping noEmit (inherited from base) lets it import sibling
    // workspace packages (e.g. @notshekhar/loop-sandbox, resolved to src via base
    // paths) without rootDir/composite constraints.
    "extends": "../../tsconfig.base.json",
    "include": ["src/**/*", "src/catalog/generated/*.json"],
    "exclude": ["src/catalog/scripts/**"]
}
